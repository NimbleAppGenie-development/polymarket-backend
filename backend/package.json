{
	"name": "backend",
	"version": "1.0.0",
	"type": "commonjs",
	"description": "",
	"main": "index.js",
	"workspaces": [
		"apps/*",
		"libs/*"
	],
	"_moduleAliases": {
		"@models": "libs/shared/models",
		"@utils": "libs/shared/utils",
		"@middleware": "libs/shared/middleware"
	},
	"scripts": {
		"prestart:user": "node libs/shared/config/updateConfig.js",
		"prestag:user": "node libs/shared/config/updateConfig.js",
		"predev:user": "node libs/shared/config/updateConfig.js",
		"test:user": "echo \"Error: no test specified\" && exit 1",
		"start:admin": "nodemon apps/admin/index.js",
		"start:user": "nodemon apps/user/index.js",
                "start:liveScores": "nodemon apps/liveScores/index.js",
		"stage:admin": "NODE_ENV=production nodemon apps/admin/src/index.js",
		"stage:user": "NODE_ENV=production nodemon apps/user/src/index.js",
		"dev:user": "NODE_ENV=development nodemon --ignore 'logs/*' --ignore 'tmp/*' index.js",
		"seed": "node src/seeder/user/index.js",
		"pm2:start:admin": "pm2 start apps/admin/index.js --name polymarket-admin-back --watch",
		"pm2:start:user": "pm2 start apps/user/index.js --name polymarket-user --watch",
		"pm2:restart:admin": "pm2 restart polymarket-admin-back",
		"pm2:restart:user": "pm2 restart polymarket-user",
		"pm2:stop:admin": "pm2 stop polymarket-admin-back",
		"pm2:stop:user": "pm2 stop polymarket-user",
		"pm2:logs:dev": "pm2 logs polymarket-user",
		"pm2:delete:dev": "pm2 delete polymarket-user"
	},
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.842.0",
		"@aws-sdk/client-secrets-manager": "^3.787.0",
		"amazon-cognito-identity-js": "^6.3.12",
		"aws-sdk": "^2.1692.0",
		"axios": "^1.8.4",
		"bcryptjs": "^2.4.3",
		"cors": "^2.8.5",
		"country-state-city": "^3.2.1",
		"crypto": "^1.0.1",
		"dayjs": "^1.11.13",
		"dotenv": "^16.6.1",
		"express": "^4.21.2",
		"firebase-admin": "^13.3.0",
		"form-data": "^4.0.2",
		"fs-extra": "^11.3.0",
		"joi": "^18.0.0",
		"jsonwebtoken": "^9.0.2",
		"libphonenumber-js": "^1.12.9",
		"module-alias": "^2.2.3",
		"moment": "^2.30.1",
		"mongoose": "^8.9.5",
		"morgan": "^1.10.0",
		"multer": "^1.4.5-lts.1",
		"multer-s3": "^3.0.1",
		"mysql2": "^3.14.1",
		"node-cron": "^3.0.3",
		"nodemailer": "^6.10.0",
		"nodemon": "^3.1.9",
		"pg": "^8.13.3",
		"pg-hstore": "^2.3.4",
		"qrcode": "^1.5.4",
		"sequelize": "^6.37.5",
		"sequelize-cli": "^6.6.2",
		"socket.io": "^4.8.1",
		"swagger-ui-express": "^5.0.1"
	},
	"devDependencies": {
		"cross-env": "^7.0.3",
		"swagger-autogen": "^2.23.7"
	}
}
